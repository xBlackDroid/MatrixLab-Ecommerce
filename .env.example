# ============================================================================
# MatrixLab Store Core — Variables de entorno (SIN valores reales)
# Copia este archivo a .env.local y completa los valores.
# NUNCA commitear .env.local ni pegar llaves en el código.
# ============================================================================

# URL pública del sitio (sin / final). Requerida para checkout:
# se usa para back_urls y notification_url de Mercado Pago.
NEXT_PUBLIC_SITE_URL=

# --- Mercado Pago (Checkout Pro) --------------------------------------------
# Access Token (credenciales de prueba o producción). SOLO backend.
# PROHIBIDO usar prefijo NEXT_PUBLIC en esta variable.
MERCADOPAGO_ACCESS_TOKEN=
# Public key (opcional; Checkout Pro funciona por redirección backend).
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
# Secreto de firma del webhook (panel de Mercado Pago → Webhooks).
# Recomendado en producción; si falta en producción, el webhook se rechaza.
MERCADOPAGO_WEBHOOK_SECRET=

# --- Base de datos -----------------------------------------------------------
# Cadena directa a Postgres (para aplicar migraciones con psql; opcional si
# usas el SQL Editor de Supabase).
DATABASE_URL=

# --- Supabase ----------------------------------------------------------------
SUPABASE_URL=
# Anon key: puede usarse en cliente SOLO porque RLS está activo.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SOLO backend. PROHIBIDO prefijo NEXT_PUBLIC. Nunca al navegador.
SUPABASE_SERVICE_ROLE_KEY=

# --- Panel admin -------------------------------------------------------------
# Contraseña de acceso al panel (mínimo 8 caracteres; usa una frase larga).
ADMIN_ACCESS_PASSWORD=
# Secreto para firmar sesiones admin (32+ caracteres aleatorios).
# Generar con: openssl rand -base64 32
ADMIN_SESSION_SECRET=

# --- Otros -------------------------------------------------------------------
PAYMENT_PROVIDER=mercadopago
NODE_ENV=development

# Número de WhatsApp comercial SIN signo + (ej. 5215512345678).
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Peso máximo de archivos del diseñador en MB (default 10, máx 50).
UPLOAD_MAX_MB=10
